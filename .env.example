# ─────────────────────────────────────────────────────────────
# Transaction Categorization Service — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# ── LLM Provider ─────────────────────────────────────────────
# Supported: openai | huggingface | anthropic
LLM_PROVIDER=openai

# OpenAI (default)
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# HuggingFace (set LLM_PROVIDER=huggingface)
# LLM_API_KEY=hf_...
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# LLM_BASE_URL=https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.2/v1

# Anthropic (set LLM_PROVIDER=anthropic)
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# ── LLM Tuning ───────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
